# Build aggregate geometries for AR island circles.
# 19 RA Açores = island districts 41..49
# 20 RA Madeira = island districts 31..32
psql -d elections -v ON_ERROR_STOP=1 <<'SQL'
WITH azores_geom AS (
    SELECT
        ST_Multi(
            ST_UnaryUnion(
                ST_Collect(t.geom)
            )
        )::geometry(MultiPolygon, 4326) AS geom
    FROM op.territory t
    JOIN op.territory_level tl
      ON tl.territory_level_id = t.level_id
    WHERE tl.code = 'district'
      AND t.code IN ('41', '42', '43', '44', '45', '46', '47', '48', '49')
      AND t.geom IS NOT NULL
),
madeira_geom AS (
    SELECT
        ST_Multi(
            ST_UnaryUnion(
                ST_Collect(t.geom)
            )
        )::geometry(MultiPolygon, 4326) AS geom
    FROM op.territory t
    JOIN op.territory_level tl
      ON tl.territory_level_id = t.level_id
    WHERE tl.code = 'district'
      AND t.code IN ('31', '32')
      AND t.geom IS NOT NULL
)
UPDATE op.territory target
SET
    geom = source.geom,
    source_table = 'derived_ar_circle_from_island_districts',
    source_srid = 4326,
    updated_at = now()
FROM (
    SELECT '19' AS code, geom FROM azores_geom
    UNION ALL
    SELECT '20' AS code, geom FROM madeira_geom
) source
WHERE target.code = source.code
  AND source.geom IS NOT NULL;
SQL

