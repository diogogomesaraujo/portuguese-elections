SELECT
    e.code AS election,
    o.code AS office,
    COUNT(*) AS turnout_rows
FROM op.turnout_result tr
JOIN op.election e
  ON e.election_id = tr.election_id
JOIN op.office o
  ON o.office_id = tr.office_id
WHERE e.code IN (
    'AUTARQUICAS_2017',
    'AUTARQUICAS_2021',
    'AUTARQUICAS_2025',
    'LEGISLATIVAS_2015',
    'LEGISLATIVAS_2019',
