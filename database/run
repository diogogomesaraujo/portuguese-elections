    'LEGISLATIVAS_2024',
    'LEGISLATIVAS_2025'
)
GROUP BY e.code, o.code
ORDER BY e.code, o.code;
"

# Seat method report.
psql -d elections -c "
SELECT
    e.code AS election,
    o.code AS office,
    sr.method,
    COUNT(*) AS rows,
    SUM(sr.seats) AS seats
FROM op.seat_result sr
JOIN op.election e
  ON e.election_id = sr.election_id
JOIN op.office o
  ON o.office_id = sr.office_id
WHERE e.code IN (
    'AUTARQUICAS_2017',
    'AUTARQUICAS_2021',
    'AUTARQUICAS_2025',
    'LEGISLATIVAS_2015',
    'LEGISLATIVAS_2019',
    'LEGISLATIVAS_2022',
    'LEGISLATIVAS_2024',
    'LEGISLATIVAS_2025'
)
GROUP BY e.code, o.code, sr.method
ORDER BY e.code, o.code, sr.method;
"

# Generic data consistency checks.
psql -d elections -c "
WITH checks AS (
    SELECT 'active_raw_placeholders' AS check_name, COUNT(*) AS bad_count
    FROM op.vote_result vr
    JOIN op.candidacy c
      ON c.candidacy_id = vr.candidacy_id
    JOIN op.political_entity pe
      ON pe.political_entity_id = c.political_entity_id
    WHERE pe.sigla ~ '^\[[A-Z]\]$'

    UNION ALL

    SELECT 'turnout_math_errors', COUNT(*)
    FROM op.result_summary rs
    JOIN op.turnout_result tr
      ON tr.election_id = rs.election_id
     AND tr.office_id = rs.office_id
     AND tr.territory_id = rs.territory_id
    WHERE rs.candidate_votes <> tr.voters - tr.blank_votes - tr.null_votes

    UNION ALL

    SELECT 'vote_context_errors', COUNT(*)
    FROM op.vote_result vr
    JOIN op.candidacy c
      ON c.candidacy_id = vr.candidacy_id
    WHERE c.election_id <> vr.election_id
       OR c.office_id <> vr.office_id
       OR c.territory_id <> vr.territory_id

    UNION ALL

    SELECT 'turnout_without_votes', COUNT(*)
    FROM op.turnout_result tr
    LEFT JOIN op.vote_result vr
      ON vr.election_id = tr.election_id
     AND vr.office_id = tr.office_id
     AND vr.territory_id = tr.territory_id
    WHERE vr.candidacy_id IS NULL

    UNION ALL

    SELECT 'wh_vote_mismatch', abs(
        (SELECT COUNT(*) FROM op.vote_result)
        -
        (SELECT COUNT(*) FROM wh.fact_vote_result)
    )

    UNION ALL

    SELECT 'wh_turnout_mismatch', abs(
        (SELECT COUNT(*) FROM op.turnout_result)
        -
        (SELECT COUNT(*) FROM wh.fact_turnout)
    )

    UNION ALL

    SELECT 'seat_result_without_seat_count', COUNT(*)
    FROM op.seat_result sr
    LEFT JOIN op.seat_count sc
      ON sc.election_id = sr.election_id
     AND sc.office_id = sr.office_id
     AND sc.territory_id = sr.territory_id
    WHERE sc.election_id IS NULL

    UNION ALL

    SELECT 'seat_allocation_errors_by_method', COUNT(*)
    FROM (
        SELECT
            sc.election_id,
            sc.office_id,
            sc.territory_id,
            sr.method,
            sc.seats AS expected_seats,
            COALESCE(SUM(sr.seats), 0) AS allocated_seats
        FROM op.seat_count sc
        JOIN op.seat_result sr
          ON sr.election_id = sc.election_id
         AND sr.office_id = sc.office_id
         AND sr.territory_id = sc.territory_id
        GROUP BY
            sc.election_id,
            sc.office_id,
            sc.territory_id,
            sr.method,
            sc.seats
    ) x
    WHERE allocated_seats <> expected_seats

    UNION ALL

    SELECT 'dhondt_calculated_contexts_missing', COUNT(*)
    FROM op.seat_count sc
    WHERE NOT EXISTS (
        SELECT 1
        FROM op.seat_result sr
        WHERE sr.election_id = sc.election_id
          AND sr.office_id = sc.office_id
          AND sr.territory_id = sc.territory_id
          AND sr.method = 'dhondt_calculated'
    )

    UNION ALL

    SELECT 'wh_seat_mismatch', abs(
        (SELECT COUNT(*) FROM op.seat_result)
        -
        (SELECT COUNT(*) FROM wh.fact_seat_result)
    )
)
SELECT
    check_name,
    bad_count,
    CASE WHEN bad_count = 0 THEN 'OK' ELSE 'FAIL' END AS status
FROM checks
ORDER BY check_name;
"

# Focused AR checks.
psql -d elections -c "
WITH expected AS (
    SELECT *
    FROM (
        VALUES
            ('LEGISLATIVAS_2022', 22::bigint, 5417715::bigint, 5564539::bigint, 63103::bigint, 83721::bigint, 230::bigint, 62::bigint),
            ('LEGISLATIVAS_2024', 22::bigint, 6194709::bigint, 6476952::bigint, 89847::bigint, 192396::bigint, 230::bigint, 77::bigint),
            ('LEGISLATIVAS_2025', 22::bigint, 6059321::bigint, 6319969::bigint, 87654::bigint, 172994::bigint, 230::bigint, 76::bigint),
            ('LEGISLATIVAS_2015', 22::bigint, 5206113::bigint, 5408092::bigint, 112955::bigint, 89024::bigint, 230::bigint, 62::bigint),
            ('LEGISLATIVAS_2019', 22::bigint, 4982609::bigint, 5237484::bigint, 131302::bigint, 123573::bigint, 230::bigint, 66::bigint)
    ) AS x(
        election_code,
        expected_circles,
        expected_candidate_votes,
        expected_voters,
        expected_blank_votes,
        expected_null_votes,
        expected_seats,
        expected_official_seat_rows
    )
),

turnout_actual AS (
    SELECT
        e.code AS election_code,
        COUNT(*)::bigint AS turnout_circles,
        COALESCE(SUM(tr.voters), 0)::bigint AS voters,
        COALESCE(SUM(tr.blank_votes), 0)::bigint AS blank_votes,
        COALESCE(SUM(tr.null_votes), 0)::bigint AS null_votes
    FROM op.election e
    JOIN op.office o
      ON o.code = 'AR'
    LEFT JOIN op.turnout_result tr
      ON tr.election_id = e.election_id
     AND tr.office_id = o.office_id
    WHERE e.code IN (
        'LEGISLATIVAS_2015',
        'LEGISLATIVAS_2019',
        'LEGISLATIVAS_2022',
        'LEGISLATIVAS_2024',
        'LEGISLATIVAS_2025'
    )
    GROUP BY e.code
),

vote_actual AS (
    SELECT
        e.code AS election_code,
        COALESCE(SUM(vr.votes), 0)::bigint AS candidate_votes
    FROM op.election e
    JOIN op.office o
      ON o.code = 'AR'
    LEFT JOIN op.vote_result vr
      ON vr.election_id = e.election_id
     AND vr.office_id = o.office_id
    WHERE e.code IN (
        'LEGISLATIVAS_2015',
        'LEGISLATIVAS_2019',
        'LEGISLATIVAS_2022',
        'LEGISLATIVAS_2024',
        'LEGISLATIVAS_2025'
    )
    GROUP BY e.code
),

seat_actual AS (
    SELECT
        e.code AS election_code,

        COALESCE(SUM(sr.seats) FILTER (WHERE sr.method = 'official'), 0)::bigint AS official_seats,
        COUNT(sr.*) FILTER (WHERE sr.method = 'official')::bigint AS official_seat_rows,

        COALESCE(SUM(sr.seats) FILTER (WHERE sr.method = 'dhondt_calculated'), 0)::bigint AS calculated_seats,
        COUNT(sr.*) FILTER (WHERE sr.method = 'dhondt_calculated')::bigint AS calculated_seat_rows
    FROM op.election e
    JOIN op.office o
      ON o.code = 'AR'
    LEFT JOIN op.seat_result sr
      ON sr.election_id = e.election_id
     AND sr.office_id = o.office_id
    WHERE e.code IN (
        'LEGISLATIVAS_2015',
        'LEGISLATIVAS_2019',
        'LEGISLATIVAS_2022',
        'LEGISLATIVAS_2024',
        'LEGISLATIVAS_2025'
    )
    GROUP BY e.code
),

turnout_math_errors AS (
    SELECT
        e.code AS election_code,
        COUNT(*)::bigint AS turnout_math_errors
    FROM op.result_summary rs
    JOIN op.turnout_result tr
      ON tr.election_id = rs.election_id
     AND tr.office_id = rs.office_id
     AND tr.territory_id = rs.territory_id
    JOIN op.election e
      ON e.election_id = rs.election_id
    JOIN op.office o
      ON o.office_id = rs.office_id
    WHERE e.code IN (
        'LEGISLATIVAS_2015',
        'LEGISLATIVAS_2019',
        'LEGISLATIVAS_2022',
        'LEGISLATIVAS_2024',
        'LEGISLATIVAS_2025'
    )
      AND o.code = 'AR'
      AND rs.candidate_votes <> tr.voters - tr.blank_votes - tr.null_votes
    GROUP BY e.code
),

checks AS (
    SELECT
        expected.election_code,
        'turnout_circles' AS check_name,
        COALESCE(turnout_actual.turnout_circles, 0) AS value,
        expected.expected_circles AS expected
    FROM expected
    LEFT JOIN turnout_actual USING (election_code)

    UNION ALL

    SELECT
        expected.election_code,
        'candidate_votes_sum',
        COALESCE(vote_actual.candidate_votes, 0),
        expected.expected_candidate_votes
    FROM expected
    LEFT JOIN vote_actual USING (election_code)

    UNION ALL

    SELECT
        expected.election_code,
        'voters_sum',
        COALESCE(turnout_actual.voters, 0),
        expected.expected_voters
    FROM expected
    LEFT JOIN turnout_actual USING (election_code)

    UNION ALL

    SELECT
        expected.election_code,
        'blank_sum',
        COALESCE(turnout_actual.blank_votes, 0),
        expected.expected_blank_votes
    FROM expected
    LEFT JOIN turnout_actual USING (election_code)

    UNION ALL

    SELECT
        expected.election_code,
        'null_sum',
        COALESCE(turnout_actual.null_votes, 0),
        expected.expected_null_votes
    FROM expected
    LEFT JOIN turnout_actual USING (election_code)

    UNION ALL

    SELECT
        expected.election_code,
        'official_seats_sum',
        COALESCE(seat_actual.official_seats, 0),
        expected.expected_seats
    FROM expected
    LEFT JOIN seat_actual USING (election_code)

    UNION ALL

    SELECT
        expected.election_code,
        'official_seat_rows',
        COALESCE(seat_actual.official_seat_rows, 0),
        expected.expected_official_seat_rows
    FROM expected
    LEFT JOIN seat_actual USING (election_code)

    UNION ALL

    SELECT
        expected.election_code,
        'calculated_seats_sum',
        COALESCE(seat_actual.calculated_seats, 0),
        expected.expected_seats
    FROM expected
    LEFT JOIN seat_actual USING (election_code)

    UNION ALL

    SELECT
        expected.election_code,
        'calculated_seat_rows_positive',
        CASE
            WHEN COALESCE(seat_actual.calculated_seat_rows, 0) > 0
            THEN 1::bigint
            ELSE 0::bigint
        END,
        1::bigint
    FROM expected
    LEFT JOIN seat_actual USING (election_code)

    UNION ALL

    SELECT
        expected.election_code,
        'turnout_math_errors',
        COALESCE(turnout_math_errors.turnout_math_errors, 0),
        0::bigint
    FROM expected
    LEFT JOIN turnout_math_errors USING (election_code)
)
SELECT
    election_code,
    check_name,
    value,
    expected,
    CASE WHEN value = expected THEN 'OK' ELSE 'FAIL' END AS status
FROM checks
ORDER BY election_code, check_name;
"

# Political order / canonical distribution check.
psql -d elections -c "
SELECT
    sigla,
    seats
FROM wh.results_for_territory_parties(
    'LEGISLATIVAS',
    2022,
    'AR',
    (
        SELECT territory_key
        FROM wh.dim_territory
        WHERE territory_code = 'PT'
        LIMIT 1
    )
)
WHERE seats > 0
ORDER BY wh.political_entity_order(sigla);
"

# Spatial coverage report.
psql -d elections -c "
SELECT
    tl.code AS level,
    COUNT(*) AS territories,
    COUNT(*) FILTER (WHERE t.geom IS NOT NULL) AS with_geom,
    COUNT(*) FILTER (WHERE t.geom IS NULL) AS without_geom,
    round(
        100.0 * COUNT(*) FILTER (WHERE t.geom IS NOT NULL) / NULLIF(COUNT(*), 0),
        2
    ) AS geom_coverage_pct
FROM op.territory t
JOIN op.territory_level tl
  ON tl.territory_level_id = t.level_id
GROUP BY tl.code
ORDER BY MIN(tl.depth);
"

# Parish geometry coverage by election.
psql -d elections -c "
SELECT
    e.code AS election,
    COUNT(DISTINCT t.territory_id) AS parishes_used,
    COUNT(DISTINCT t.territory_id) FILTER (WHERE t.geom IS NOT NULL) AS parishes_with_geom,
    COUNT(DISTINCT t.territory_id) FILTER (WHERE t.geom IS NULL) AS parishes_without_geom,
    round(
        100.0 * COUNT(DISTINCT t.territory_id) FILTER (WHERE t.geom IS NOT NULL)
        / NULLIF(COUNT(DISTINCT t.territory_id), 0),
        2
    ) AS parish_geom_coverage_pct
FROM op.turnout_result tr
JOIN op.election e
  ON e.election_id = tr.election_id
JOIN op.office o
  ON o.office_id = tr.office_id
JOIN op.territory t
  ON t.territory_id = tr.territory_id
JOIN op.territory_level tl
  ON tl.territory_level_id = t.level_id
WHERE o.code = 'AF'
  AND tl.code = 'parish'
GROUP BY e.code
ORDER BY e.code;
"

# Spatial consistency check.
psql -d elections -c "
WITH checks AS (
    SELECT
        'country_has_geom' AS check_name,
        COUNT(*) FILTER (WHERE t.geom IS NULL) AS bad_count
    FROM op.territory t
    JOIN op.territory_level tl
      ON tl.territory_level_id = t.level_id
    WHERE tl.code = 'country'

    UNION ALL

    SELECT
        'districts_have_geom_except_ar_foreign_circles',
        COUNT(*) FILTER (WHERE t.geom IS NULL)
    FROM op.territory t
    JOIN op.territory_level tl
      ON tl.territory_level_id = t.level_id
    WHERE tl.code = 'district'
      AND t.code NOT IN ('21', '22')

    UNION ALL

    SELECT
        'municipalities_have_geom',
        COUNT(*) FILTER (WHERE t.geom IS NULL)
    FROM op.territory t
    JOIN op.territory_level tl
      ON tl.territory_level_id = t.level_id
    WHERE tl.code = 'municipality'

    UNION ALL

    SELECT
        'invalid_geometries',
        COUNT(*)
    FROM op.territory
    WHERE geom IS NOT NULL
      AND NOT ST_IsValid(geom)

    UNION ALL

    SELECT
        'empty_geometries',
        COUNT(*)
    FROM op.territory
    WHERE geom IS NOT NULL
      AND ST_IsEmpty(geom)

    UNION ALL

    SELECT
        'wrong_srid',
        COUNT(*)
    FROM op.territory
    WHERE geom IS NOT NULL
      AND ST_SRID(geom) <> 4326

    UNION ALL

    SELECT
        'fake_municipality_xx00',
        COUNT(*)
    FROM op.territory t
    JOIN op.territory_level tl
      ON tl.territory_level_id = t.level_id
    WHERE tl.code = 'municipality'
      AND t.code LIKE '__00'

    UNION ALL

    SELECT
        'orphan_non_country_territories',
        COUNT(*)
    FROM op.territory t
    JOIN op.territory_level tl
      ON tl.territory_level_id = t.level_id
    WHERE tl.code <> 'country'
      AND t.parent_id IS NULL

    UNION ALL

    SELECT
        'bad_parent_depth_real_errors',
        COUNT(*)
    FROM op.territory child
    JOIN op.territory parent
      ON parent.territory_id = child.parent_id
    JOIN op.territory_level cl
      ON cl.territory_level_id = child.level_id
    JOIN op.territory_level pl
      ON pl.territory_level_id = parent.level_id
    WHERE cl.depth <> pl.depth + 1
      AND NOT (
          cl.code = 'parish'
          AND pl.code = 'district'
          AND (
              child.code LIKE '____00'
              OR child.code LIKE '__0000'
          )
      )

    UNION ALL

    SELECT
        'non_parish_without_geom_used_in_results_except_ar_foreign_circles',
        COUNT(DISTINCT t.territory_id)
    FROM op.turnout_result tr
    JOIN op.election e
      ON e.election_id = tr.election_id
    JOIN op.office o
      ON o.office_id = tr.office_id
    JOIN op.territory t
      ON t.territory_id = tr.territory_id
    JOIN op.territory_level tl
      ON tl.territory_level_id = t.level_id
    WHERE tl.code IN ('country', 'district', 'municipality')
      AND t.geom IS NULL
      AND NOT (
          e.code IN (
              'LEGISLATIVAS_2015',
              'LEGISLATIVAS_2019',
              'LEGISLATIVAS_2022',
              'LEGISLATIVAS_2024',
              'LEGISLATIVAS_2025'
          )
          AND o.code = 'AR'
          AND t.code IN ('21', '22')
      )

    UNION ALL

    SELECT
        'municipality_geom_not_covered_by_district',
        COUNT(*)
    FROM op.territory m
    JOIN op.territory d
      ON d.territory_id = m.parent_id
    JOIN op.territory_level ml
      ON ml.territory_level_id = m.level_id
    JOIN op.territory_level dl
      ON dl.territory_level_id = d.level_id
    WHERE ml.code = 'municipality'
      AND dl.code = 'district'
      AND m.geom IS NOT NULL
      AND d.geom IS NOT NULL
      AND NOT (
          ST_Covers(d.geom, m.geom)
          OR ST_Area(ST_Difference(m.geom, d.geom)::geography) < 100
      )

    UNION ALL

    SELECT
        'parish_geom_not_covered_by_municipality',
        COUNT(*)
    FROM op.territory f
    JOIN op.territory m
      ON m.territory_id = f.parent_id
    JOIN op.territory_level fl
      ON fl.territory_level_id = f.level_id
    JOIN op.territory_level ml
      ON ml.territory_level_id = m.level_id
    WHERE fl.code = 'parish'
      AND ml.code = 'municipality'
      AND f.geom IS NOT NULL
      AND m.geom IS NOT NULL
      AND NOT (
          ST_Covers(m.geom, f.geom)
          OR ST_Area(ST_Difference(f.geom, m.geom)::geography) < 100
      )
)
SELECT
    check_name,
    bad_count,
    CASE WHEN bad_count = 0 THEN 'OK' ELSE 'FAIL' END AS status
FROM checks
ORDER BY check_name;
"

psql -d elections -v ON_ERROR_STOP=1 -f sql/init/cleanup.sql
