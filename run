export DATABASE_URL='postgresql://localhost/elections'


# Import spatial source tables.
# This file is large, so ON_ERROR_STOP makes failures explicit.
psql -d elections -c "
DROP TABLE IF EXISTS public.cont_freguesias CASCADE;
DROP TABLE IF EXISTS public.raa_cen_ori_freguesias CASCADE;
DROP TABLE IF EXISTS public.raa_oci_freguesias CASCADE;
DROP TABLE IF EXISTS public.ram_freguesias CASCADE;
DROP TABLE IF EXISTS public.taxi_stands CASCADE;
DROP TABLE IF EXISTS public.tracks_braga CASCADE;
"
psql -d elections -v ON_ERROR_STOP=1 -f data/spatial_class_tables.sql

# Create/update spatial enrichment procedure.
psql -d elections -f sql/import_spatial.sql


